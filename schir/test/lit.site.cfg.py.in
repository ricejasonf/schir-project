@LIT_SITE_CFG_IN_HEADER@
# In case you forgot, these are substituted by cmake_configure_file

from lit import llvm

config.schir_module_path = "@SCHIR_MODULE_PATH@"
config.schir_tools_dir = "@CMAKE_BINARY_DIR@/bin"
config.llvm_tools_dir = "@LLVM_TOOLS_DIR@"
config.schir_lib_dir = "@CMAKE_BINARY_DIR@/lib"
config.test_exec_root = "@CMAKE_CURRENT_BINARY_DIR@"

llvm.initialize(lit_config, config)
lit_config.load_config(config, "@CMAKE_CURRENT_SOURCE_DIR@/lit.cfg.py")
